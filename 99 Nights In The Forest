-- ── Log entry builder ───────────────────────────────────────
local logOrder = 0

local function addConsoleEntry(kind, text)
    logOrder = logOrder + 1

    -- Trim old entries if over limit
    if #consoleLogs >= MAX_LOGS then
        local oldest = consoleLogs[1]
        if oldest and oldest.Parent then
            oldest:Destroy()
        end
        table.remove(consoleLogs, 1)
    end

    -- Timestamp
    local h = math.floor(tick() / 3600) % 24
    local m = math.floor(tick() / 60) % 60
    local s = math.floor(tick()) % 60
    local timeStr = string.format("%02d:%02d:%02d", h, m, s)

    -- Colours
    local bgColor, textColor, tagText, tagColor
    if kind == "warn" then
        bgColor   = Color3.fromRGB(45, 38, 20)
        textColor = Color3.fromRGB(255, 210, 80)
        tagText   = "WARN"
        tagColor  = Color3.fromRGB(255, 165, 0)
    elseif kind == "error" then
        bgColor   = Color3.fromRGB(45, 20, 20)
        textColor = Color3.fromRGB(255, 100, 100)
        tagText   = "ERR"
        tagColor  = Color3.fromRGB(255, 60, 60)
    else
        bgColor   = Color3.fromRGB(25, 25, 30)
        textColor = Color3.fromRGB(200, 200, 200)
        tagText   = "LOG"
        tagColor  = Color3.fromRGB(100, 200, 100)
    end

    -- Row frame (auto-height via TextWrapped)
    local row = new("Frame", {
        Parent = consoleScroll,
        Size = UDim2.new(1, -8, 0, 28),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = bgColor,
        BorderSizePixel = 0,
        LayoutOrder = logOrder,
        ZIndex = 13
    })
    new("UICorner", { Parent = row, CornerRadius = UDim.new(0, 5) })

    -- Tag badge
    local tag = new("TextLabel", {
        Parent = row,
        Size = UDim2.new(0, 38, 0, 22),
        Position = UDim2.fromOffset(4, 3),
        BackgroundColor3 = tagColor,
        Text = tagText,
        TextSize = 10,
        TextColor3 = Color3.fromRGB(15, 15, 15),
        Font = Enum.Font.GothamBold,
        ZIndex = 14
    })
    new("UICorner", { Parent = tag, CornerRadius = UDim.new(0, 4) })

    -- Timestamp
    new("TextLabel", {
        Parent = row,
        Size = UDim2.new(0, 65, 0, 22),
        Position = UDim2.fromOffset(46, 3),
        BackgroundTransparency = 1,
        Text = timeStr,
        TextSize = 10,
        TextColor3 = Color3.fromRGB(100, 100, 120),
        Font = Enum.Font.Code,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 14
    })

    -- Message (wraps)
    new("TextLabel", {
        Parent = row,
        Size = UDim2.new(1, -120, 0, 22),
        AutomaticSize = Enum.AutomaticSize.Y,
        Position = UDim2.fromOffset(114, 3),
        BackgroundTransparency = 1,
        Text = tostring(text),
        TextSize = 11,
        TextColor3 = textColor,
        Font = Enum.Font.Code,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        ZIndex = 14
    })

    table.insert(consoleLogs, row)

    -- Update counter
    logCountLabel.Text = #consoleLogs .. " / " .. MAX_LOGS .. " logs"

    -- Auto-scroll to bottom
    task.defer(function()
        consoleScroll.CanvasPosition = Vector2.new(0, math.huge)
    end)
end


-- Spin Functions
local function spinCircle(angle, radius, center)
    local rad = math.rad(angle)
    local x = center.X + radius * math.cos(rad)
    local z = center.Z + radius * math.sin(rad)
    return Vector3.new(x, center.Y, z)
end

local function spinSquare(angle, radius, center)
    local side = angle % 90
    local quadrant = math.floor(angle / 90) % 4
    local offset = (side / 90) * radius * 2 - radius
    
    if quadrant == 0 then
        return Vector3.new(center.X + radius, center.Y, center.Z + offset)
    elseif quadrant == 1 then
        return Vector3.new(center.X - offset, center.Y, center.Z + radius)
    elseif quadrant == 2 then
        return Vector3.new(center.X - radius, center.Y, center.Z - offset)
    else
        return Vector3.new(center.X + offset, center.Y, center.Z - radius)
    end
end

local function spinFigure8(angle, radius, center)
    local rad = math.rad(angle)
    local x = center.X + radius * math.sin(rad)
    local z = center.Z + radius * math.sin(rad * 2) / 2
    return Vector3.new(x, center.Y, z)
end

createToggle(tab3, "🌀 Start Spinning", function(enabled)
    spinning = enabled
    
    if enabled then
        spinSpeed = tonumber(spinSpeedBox.Text) or 50
        spinRadius = tonumber(spinRadiusBox.Text) or 100
        spinHeight = tonumber(spinHeightBox.Text) or 50
        local radiusIncrease = tonumber(radiusIncreaseBox.Text) or 10
        
        if spinConnection then spinConnection:Disconnect() end
        
        local angle = 0
        local centerPos = Vector3.new(0, spinHeight, 0)
        local lastUpdate = tick()
        local currentRadius = spinRadius -- Track current radius
        
        spinConnection = RunService.Heartbeat:Connect(function()
            if not spinning then return end
            
            local hrp = getHrp()
            if not hrp then return end
            
            -- Delta time compensation for lag (anti-lag)
            local now = tick()
            local deltaTime = now - lastUpdate
            lastUpdate = now
            
            -- Clamp delta time to prevent huge jumps during lag spikes
            deltaTime = math.min(deltaTime, 0.1)
            
            -- Update angle with delta time compensation
            angle = angle + (spinSpeed / 100) * (deltaTime * 60) -- Normalize to 60 FPS
            
            -- After full spin, increase radius
            if angle >= 360 then
                angle = 0
                currentRadius = currentRadius + radiusIncrease
                print("🌀 Spin complete! New radius: " .. currentRadius)
            end
            
            local newPos
            if spinPattern == "Circle" then
                newPos = spinCircle(angle, currentRadius, centerPos)
            elseif spinPattern == "Square" then
                newPos = spinSquare(angle, currentRadius, centerPos)
            elseif spinPattern == "Figure8" then
                newPos = spinFigure8(angle, currentRadius, centerPos)
            end
            
            -- Use CFrame for instant positioning (ignores physics/lag)
            hrp.CFrame = CFrame.new(newPos)
            
            -- Force velocity to zero to prevent physics interference
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end)
        
        print("🌀 Spinning: " .. spinPattern .. " | Speed: " .. spinSpeed .. " | Start Radius: " .. spinRadius .. " | Increase: " .. radiusIncrease)
    else
        if spinConnection then
            spinConnection:Disconnect()
            spinConnection = nil
        end
        print("❌ Spinning: OFF")
    end
end)


-- Auto Fuel Function
local function autoFuelCampfire()
    if not autoFuelEnabled then return end
    
    local itemsFolder = workspace:FindFirstChild("Items")
    if not itemsFolder then return end
    
    local dragRemote = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if dragRemote then
        dragRemote = dragRemote:FindFirstChild("RequestStartDraggingItem")
    end
    
    local stopRemote = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if stopRemote then
        stopRemote = stopRemote:FindFirstChild("RequestStopDraggingItem")
    end
    
    if not dragRemote or not stopRemote then return end
    
    local fuelCount = 0
    
    -- Scan for selected fuel types
    for _, fuelType in ipairs(selectedFuelTypes) do
        for _, item in ipairs(itemsFolder:GetChildren()) do
            if item.Name == fuelType and item:IsA("Model") then
                -- Set primary part if needed
                if not item.PrimaryPart then
                    for _, part in ipairs(item:GetDescendants()) do
                        if part:IsA("BasePart") then
                            item.PrimaryPart = part
                            break
                        end
                    end
                end
                
                if item.PrimaryPart then
                    pcall(function()
                        -- Teleport to campfire
                        item:SetPrimaryPartCFrame(CFrame.new(campfirePos))
                        
                        -- Start dragging
                        dragRemote:FireServer(item)
                        
                        -- Wait 3 frames
                        task.wait()
                        
                        -- Stop dragging (places item)
                        stopRemote:FireServer(item)
                        
                        fuelCount = fuelCount + 1
                    end)
                end
            end
        end
    end
    
    if fuelCount > 0 then
        print("🔥 Auto Fuel: Brought " .. fuelCount .. " fuel items to campfire")
    end
end


-- Pattern Generation Function (MUST BE BEFORE BLUEPRINT TOGGLE!)
local function generatePattern(pattern, count, radius, center)
    local positions = {}
    
    if pattern == "Me" then
        -- Place all saplings at player position
        for i = 1, count do
            table.insert(positions, Vector3.new(center.X, center.Y, center.Z))
        end
    elseif pattern == "Circle" then
        for i = 1, count do
            local angle = (i / count) * math.pi * 2
            local x = center.X + math.cos(angle) * radius
            local z = center.Z + math.sin(angle) * radius
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Square" then
        local perSide = math.ceil(count / 4)
        local side = radius * 2
        for i = 1, count do
            local progress = (i - 1) / count
            local x, z
            if progress < 0.25 then
                x = center.X - radius + (progress * 4) * side
                z = center.Z - radius
            elseif progress < 0.5 then
                x = center.X + radius
                z = center.Z - radius + ((progress - 0.25) * 4) * side
            elseif progress < 0.75 then
                x = center.X + radius - ((progress - 0.5) * 4) * side
                z = center.Z + radius
            else
                x = center.X - radius
                z = center.Z + radius - ((progress - 0.75) * 4) * side
            end
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Grid" then
        local gridSize = math.ceil(math.sqrt(count))
        local spacing = (radius * 2) / gridSize
        for i = 1, count do
            local row = math.floor((i - 1) / gridSize)
            local col = (i - 1) % gridSize
            local x = center.X - radius + col * spacing
            local z = center.Z - radius + row * spacing
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Spiral" then
        for i = 1, count do
            local angle = i * 0.5
            local distance = (i / count) * radius
            local x = center.X + math.cos(angle) * distance
            local z = center.Z + math.sin(angle) * distance
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Star" then
        -- True 5-pointed star: 10 vertices alternating outer/inner, saplings along edges
        local outerR = radius
        local innerR = radius * 0.382  -- golden ratio inner radius for a perfect star
        local numPoints = 5
        local vertices = {}
        for v = 0, numPoints * 2 - 1 do
            local a = (v / (numPoints * 2)) * math.pi * 2 - math.pi / 2
            local r = (v % 2 == 0) and outerR or innerR
            table.insert(vertices, {x = center.X + math.cos(a) * r, z = center.Z + math.sin(a) * r})
        end
        -- Distribute saplings evenly along the 10 star edges
        local numEdges = numPoints * 2
        local perEdge = math.max(1, math.floor(count / numEdges))
        local placed = 0
        for e = 1, numEdges do
            local va = vertices[e]
            local vb = vertices[(e % numEdges) + 1]
            local edgeCount = (e == numEdges) and (count - placed) or perEdge
            for j = 0, edgeCount - 1 do
                local t = j / math.max(edgeCount, 1)
                table.insert(positions, Vector3.new(
                    va.x + (vb.x - va.x) * t,
                    center.Y,
                    va.z + (vb.z - va.z) * t
                ))
                placed = placed + 1
            end
        end
    elseif pattern == "Random" then
        for i = 1, count do
            local randomAngle = math.random() * math.pi * 2
            local randomDistance = math.random() * radius
            local x = center.X + math.cos(randomAngle) * randomDistance
            local z = center.Z + math.sin(randomAngle) * randomDistance
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Ring" then
        -- True double ring: outer ring + inner ring (two concentric circles)
        local outerCount = math.ceil(count * 0.6)   -- 60% on outer ring
        local innerCount = count - outerCount        -- 40% on inner ring
        for i = 1, outerCount do
            local angle = ((i - 1) / outerCount) * math.pi * 2
            table.insert(positions, Vector3.new(
                center.X + math.cos(angle) * radius,
                center.Y,
                center.Z + math.sin(angle) * radius
            ))
        end
        for i = 1, innerCount do
            local angle = ((i - 1) / innerCount) * math.pi * 2
            table.insert(positions, Vector3.new(
                center.X + math.cos(angle) * (radius * 0.5),
                center.Y,
                center.Z + math.sin(angle) * (radius * 0.5)
            ))
        end
    elseif pattern == "Cross" then
        local perArm = math.floor(count / 4)
        local spacing = radius / math.max(perArm, 1)
        for i = 1, perArm do
            table.insert(positions, Vector3.new(center.X + i*spacing, center.Y, center.Z))
            table.insert(positions, Vector3.new(center.X - i*spacing, center.Y, center.Z))
            table.insert(positions, Vector3.new(center.X, center.Y, center.Z + i*spacing))
            table.insert(positions, Vector3.new(center.X, center.Y, center.Z - i*spacing))
        end
    elseif pattern == "Diamond" then
        -- Brilliant-cut diamond viewed from above:
        -- 1. Outer girdle (circle)
        -- 2. Inner table (octagon)
        -- 3. 8 radial facet lines from table to girdle
        -- 4. Centre point
        local numFacets = 8
        local tableR    = radius * 0.38   -- table octagon radius
        local girdle    = radius           -- outer edge

        -- Budget split: 35% girdle, 25% table, 30% facet lines, 10% centre star
        local girdleCount  = math.floor(count * 0.35)
        local tableCount   = math.floor(count * 0.25)
        local facetCount   = math.floor(count * 0.30)
        local starCount    = count - girdleCount - tableCount - facetCount

        -- 1. Outer girdle ring
        for i = 1, girdleCount do
            local a = ((i - 1) / girdleCount) * math.pi * 2
            table.insert(positions, Vector3.new(
                center.X + math.cos(a) * girdle, center.Y,
                center.Z + math.sin(a) * girdle))
        end

        -- 2. Inner table (octagon)
        for i = 1, tableCount do
            local a = ((i - 1) / tableCount) * math.pi * 2
            -- snap angle to nearest octagon vertex for a clean faceted edge
            local snap = math.floor(a / (math.pi / 4) + 0.5) * (math.pi / 4)
            local blend = 0.5   -- 0=pure octagon edge, 1=pure circle
            local ax = math.cos(a) * (1 - blend) + math.cos(snap) * blend
            local az = math.sin(a) * (1 - blend) + math.sin(snap) * blend
            local len = math.sqrt(ax * ax + az * az)
            table.insert(positions, Vector3.new(
                center.X + (ax / len) * tableR, center.Y,
                center.Z + (az / len) * tableR))
        end

        -- 3. Eight radial facet lines (table → girdle)
        local perLine = math.max(2, math.floor(facetCount / numFacets))
        local fPlaced = 0
        for f = 0, numFacets - 1 do
            local a = (f / numFacets) * math.pi * 2 + math.pi / numFacets
            local lineCount = (f == numFacets - 1) and (facetCount - fPlaced) or perLine
            for j = 0, lineCount - 1 do
                local t = tableR + (girdle - tableR) * (j / math.max(lineCount - 1, 1))
                table.insert(positions, Vector3.new(
                    center.X + math.cos(a) * t, center.Y,
                    center.Z + math.sin(a) * t))
                fPlaced = fPlaced + 1
            end
        end

        -- 4. Centre star (8 short spokes from origin outward, very short)
        local starR = tableR * 0.5
        for i = 1, starCount do
            local a = ((i - 1) / starCount) * math.pi * 2
            local t  = (i % 3 == 0) and starR or starR * 0.45
            table.insert(positions, Vector3.new(
                center.X + math.cos(a) * t, center.Y,
                center.Z + math.sin(a) * t))
        end
    elseif pattern == "Wave" then
        local spacing = (radius * 2) / count
        for i = 1, count do
            local x = center.X - radius + (i-1) * spacing
            local z = center.Z + math.sin(i * 0.5) * (radius * 0.5)
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    elseif pattern == "Triangle" then
        local perSide = math.ceil(count / 3)
        local pts = {
            Vector3.new(center.X, center.Y, center.Z - radius),
            Vector3.new(center.X + radius*0.866, center.Y, center.Z + radius*0.5),
            Vector3.new(center.X - radius*0.866, center.Y, center.Z + radius*0.5)
        }
        for s = 1, 3 do
            local a, b = pts[s], pts[s%3+1]
            for j = 0, perSide-1 do
                local t = j / perSide
                table.insert(positions, Vector3.new(a.X+(b.X-a.X)*t, center.Y, a.Z+(b.Z-a.Z)*t))
            end
        end
    elseif pattern == "Zigzag" then
        local spacing = (radius * 2) / count
        for i = 1, count do
            local x = center.X - radius + (i-1) * spacing
            local z = center.Z + ((i%2==0) and (radius*0.4) or -(radius*0.4))
            table.insert(positions, Vector3.new(x, center.Y, z))
        end
    end
    
    return positions
end

-- Update Blueprint Function
local function updateBlueprint()
    if not blueprintEnabled then return end
    
    -- Get center position based on setting
    local center
    if centerPosition == "Campfire" then
        center = campfirePos
    else
        local hrp = getHrp()
        if not hrp then return end
        center = hrp.Position
    end
    
    local positions = generatePattern(saplingPattern, saplingCount, saplingRadius, center)
    
    -- If we need more parts, create them
    while #blueprintParts < #positions do
        local part = Instance.new("Part")
        part.Size = Vector3.new(3, 0.5, 3)
        part.Anchored = true
        part.CanCollide = false
        part.Transparency = 0.5
        part.Color = Color3.fromRGB(0, 255, 0)
        part.Material = Enum.Material.Neon
        part.Parent = workspace
        table.insert(blueprintParts, part)
    end
    
    -- If we have too many parts, remove extras
    while #blueprintParts > #positions do
        local part = table.remove(blueprintParts)
        if part and part.Parent then
            part:Destroy()
        end
    end
    
    -- Update positions of existing parts
    for i, pos in ipairs(positions) do
        if blueprintParts[i] then
            blueprintParts[i].Position = pos
        end
    end
end


-- AUTO-DETECT VOID DEPTH
-- ════════════════════════════════════════════════════════════

local voidY = -500 -- Default

local function detectVoidDepth()
    updateLoading(0.3, "Detecting void depth...")
    task.wait(0.2)
    
    local workspace = game:GetService("Workspace")
    
    -- Method 1: Try FallenPartsDestroyHeight (may not exist or be readable)
    local success, result = pcall(function()
        return workspace.FallenPartsDestroyHeight
    end)
    
    if success and result then
        voidY = result
        print("🌀 Void from FallenPartsDestroyHeight: Y = " .. voidY)
        return
    end
    
    -- Method 2: Find lowest solid ground
    local lowestY = 0
    local foundGround = false
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.CanCollide then
            foundGround = true
            if obj.Position.Y < lowestY then
                lowestY = obj.Position.Y
            end
        end
    end
    
    if foundGround and lowestY < 0 then
        voidY = lowestY - 50
        print("🌀 Void from lowest ground: Y = " .. voidY .. " (ground at Y = " .. lowestY .. ")")
    else
        voidY = -500
        print("🌀 Void using default: Y = " .. voidY)
    end
end


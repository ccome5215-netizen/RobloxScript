bringBtn.MouseButton1Click:Connect(function()
    if isBringing then
        print("⚠️ Already bringing items!")
        return
    end
    
    isBringing = true
    print("✨ Bring operation started! (ULTRA INSTANT - Heartbeat)")
    
    task.spawn(function()
        local hrp = getHrp()
        if not hrp then
            print("❌ HRP not found")
            isBringing = false
            return
        end
        
        local folder = getItemsFolder()
        if not folder then
            print("❌ Items folder not found")
            isBringing = false
            return
        end
        
        local remote = getDragRemote()
        local pool = {}
        
        -- BUILD POOL
        if multiItemMode and #selectedItems > 0 then
            print("📦 Multi-Item Mode: " .. table.concat(selectedItems, ", "))
            for _, selectedName in ipairs(selectedItems) do
                if not isBringing then break end
                for _, item in ipairs(folder:GetChildren()) do
                    if item:IsA("Model") and item.Name == selectedName and ensurePrimary(item) then
                        table.insert(pool, item)
                    end
                end
            end
        else
            local matcher = buildMatcher()
            for _, item in ipairs(folder:GetChildren()) do
                if not isBringing then break end
                if item:IsA("Model") and ensurePrimary(item) and matcher(item.Name) then
                    table.insert(pool, item)
                end
            end
        end
        
        if not isBringing then
            isBringing = false
            return
        end
        
        local limit = noLimitEnabled and math.huge or (tonumber(limitBox.Text) or bringLimitDefault)
        
        print("🚀 Pool: " .. #pool .. " | Batch: " .. batchSize .. " | Limit: " .. (limit == math.huge and "∞" or limit))
        
        -- Determine target
        local targetCFrame
        if bringTarget == "Me" then
            targetCFrame = hrp.CFrame
        else
            local v = bringTargets[bringTarget]
            targetCFrame = v and CFrame.new(v) or hrp.CFrame
        end
        
        -- Process batches with ULTRA FAST Heartbeat waiting
        local totalBrought = 0
        local batchCount = 0
        
        for i = 1, #pool, batchSize do
            if not isBringing then break end
            
            batchCount = batchCount + 1
            local batchItems = {}
            
            for j = i, math.min(i + batchSize - 1, #pool) do
                if not isBringing or totalBrought >= limit then break end
                table.insert(batchItems, pool[j])
                totalBrought = totalBrought + 1
            end
            
            if #batchItems == 0 then break end
            
            -- Teleport items
            for _, item in ipairs(batchItems) do
                if not isBringing then break end
                pcall(function()
                    item:SetPrimaryPartCFrame(targetCFrame)
                end)
            end
            
            if not isBringing then break end
            
            -- Start Grab
            if remote then
                for _, item in ipairs(batchItems) do
                    if not isBringing then break end
                    pcall(function() remote:FireServer(item) end)
                end
                
                if not isBringing then break end
                
                -- Stop Grab (if not private) - HEARTBEAT WAIT
                if not bringItemPrivate then
                    -- Wait 3 frames using Heartbeat (ULTRA FAST)
                    local frameCount = 0
                    local waitConnection
                    waitConnection = RunService.Heartbeat:Connect(function()
                        frameCount = frameCount + 1
                        if frameCount >= 3 then
                            waitConnection:Disconnect()
                        end
                    end)
                    
                    -- Wait for frames to complete
                    while frameCount < 3 do
                        RunService.Heartbeat:Wait()
                    end
                    
                    local stopRemote = ReplicatedStorage:FindFirstChild("RemoteEvents")
                    if stopRemote then
                        stopRemote = stopRemote:FindFirstChild("RequestStopDraggingItem")
                    end
                    
                    if stopRemote then
                        for _, item in ipairs(batchItems) do
                            if not isBringing then break end
                            pcall(function() stopRemote:FireServer(item) end)
                        end
                    end
                end
            end
            
            if not isBringing then break end
            
            print("✅ Batch " .. batchCount .. " complete! (" .. #batchItems .. " items)")
            
            -- Wait between batches - HEARTBEAT MODE (Every 60 frames)
            if currentDelay == -1 then
                -- No wait - instant
            elseif currentDelay and currentDelay > 0 then
                -- Use Heartbeat for precise frame-based waiting
                local frameTarget = math.floor(currentDelay * 60) -- Convert seconds to frames
                local frameCount = 0
                local waitConnection
                waitConnection = RunService.Heartbeat:Connect(function()
                    frameCount = frameCount + 1
                    if frameCount >= frameTarget then
                        waitConnection:Disconnect()
                    end
                end)
                
                while frameCount < frameTarget and isBringing do
                    RunService.Heartbeat:Wait()
                end
                
                if waitConnection then waitConnection:Disconnect() end
            else
                -- Default: Wait 60 frames (1 second at 60 FPS)
                local frameCount = 0
                local waitConnection
                waitConnection = RunService.Heartbeat:Connect(function()
                    frameCount = frameCount + 1
                    if frameCount >= 60 then
                        waitConnection:Disconnect()
                    end
                end)
                
                while frameCount < 60 and isBringing do
                    RunService.Heartbeat:Wait()
                end
                
                if waitConnection then waitConnection:Disconnect() end
            end
            
            if totalBrought >= limit then break end
        end
        
        if isBringing then
            print("✨ BRING COMPLETE! " .. totalBrought .. " items in " .. batchCount .. " batches (ULTRA INSTANT)")
        end
        
        isBringing = false
    end)
end)


local allFilterOptions = {}

local function populateFilterList(searchQuery)
    for _, child in ipairs(filterScrollFrame:GetChildren()) do
        if child ~= filterListLayout then child:Destroy() end
    end
    
    if #allFilterOptions == 0 then allFilterOptions = collectFilterOptions() end
    local query = (searchQuery or ""):lower()
    local filteredOptions = {}
    
    for _, opt in ipairs(allFilterOptions) do
        if query == "" or opt:lower():find(query, 1, true) then
            table.insert(filteredOptions, opt)
        end
    end
    
    for _, opt in ipairs(filteredOptions) do
        local isSelected = false
        if multiItemMode then
            for _, selectedItem in ipairs(selectedItems) do
                if selectedItem == opt then
                    isSelected = true
                    break
                end
            end
        end
        
        local btn = new("TextButton", {
            Parent = filterScrollFrame,
            Size = UDim2.new(1, -6, 0, 32),
            Text = isSelected and ("✅ " .. opt) or opt,
            BackgroundColor3 = (isSelected or (opt == currentFilter and not multiItemMode)) and Color3.fromRGB(138, 43, 226) or Color3.fromRGB(60, 60, 65),
            TextColor3 = Color3.fromRGB(255, 255, 255),
            Font = (isSelected or opt == currentFilter) and Enum.Font.GothamBold or Enum.Font.Gotham,
            TextSize = 13,
            BorderSizePixel = 0,
            ZIndex = 22
        })
        new("UICorner", { Parent = btn, CornerRadius = UDim.new(0, 8) })
        
        btn.MouseButton1Click:Connect(function()
            if multiItemMode then
                local found = false
                for idx, selectedItem in ipairs(selectedItems) do
                    if selectedItem == opt then
                        table.remove(selectedItems, idx)
                        found = true
                        break
                    end
                end
                
                if not found then
                    table.insert(selectedItems, opt)
                end
                
                populateFilterList(filterSearchBox.Text)
            else
                currentFilter = opt
                filterBtn.Text = "🔍 " .. opt .. " ▾"
                filterList.Visible = false
                filterSearchBox.Text = ""
            end
        end)
    end
    
    local maxHeight = 250
    local contentHeight = #filteredOptions * 38 + 47
    local finalHeight = math.min(contentHeight, maxHeight)
    filterList.Size = UDim2.new(0, filterBtn.AbsoluteSize.X, 0, finalHeight)

local function buildMatcher()
    if currentFilter == "All Items" then
        return function(name)
            local ln = tostring(name or ""):lower()
            return not ln:find("chest", 1, true) and not ln:find("crate", 1, true)
        end
    else
        local key = tostring(currentFilter or ""):lower()
        return function(name)
            return tostring(name or ""):lower() == key
        end
    end
end

local function collectFilterOptions()
    local defaults = { "All Items" }
    local seen = { ["all items"] = true }
    local folder = getItemsFolder()
    if folder then
        for _, item in ipairs(folder:GetChildren()) do
            if item:IsA("Model") then
                local name = tostring(item.Name or "")
                if name ~= "" and not name:lower():find("chest", 1, true) and not name:lower():find("crate", 1, true) and not seen[name:lower()] then
                    table.insert(defaults, name)
                    seen[name:lower()] = true
                end
            end
        end
    end
    return defaults
end


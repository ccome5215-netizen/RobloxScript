-- Update Status EVERY Heartbeat (Real-Time!)
RunService.Heartbeat:Connect(function()
    local humanoid = getHumanoid()
    local hrp = getHrp()
    
    if humanoid then
        -- Health
        local health = math.floor(humanoid.Health)
        local maxHealth = math.floor(humanoid.MaxHealth)
        statusLabels["Health"].Text = "❤️ Health: " .. health
        statusLabels["MaxHealth"].Text = "💚 Max Health: " .. maxHealth
        
        -- WalkSpeed
        local walkSpeed = math.floor(humanoid.WalkSpeed)
        statusLabels["WalkSpeed"].Text = "🏃 WalkSpeed: " .. walkSpeed
        
        -- JumpPower (old) or JumpHeight (new)
        if humanoid.UseJumpPower then
            local jumpPower = math.floor(humanoid.JumpPower)
            statusLabels["JumpPower"].Text = "⬆️ JumpPower: " .. jumpPower
            statusLabels["JumpHeight"].Text = "📏 JumpHeight: N/A"
        else
            local jumpHeight = math.floor(humanoid.JumpHeight * 10) / 10
            statusLabels["JumpPower"].Text = "⬆️ JumpPower: N/A"
            statusLabels["JumpHeight"].Text = "📏 JumpHeight: " .. jumpHeight
        end
    end
    
    if hrp then
        -- Position
        local pos = hrp.Position
        local posText = string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z)
        statusLabels["Position"].Text = "📍 Position: " .. posText
    end
    
    -- FPS Counter
    fpsCounter = fpsCounter + 1
    local now = tick()
    if now - lastFPSUpdate >= 1 then
        statusLabels["FPS"].Text = "🎮 FPS: " .. fpsCounter
        fpsCounter = 0
        lastFPSUpdate = now
    end
    
    -- Ping
    local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
    statusLabels["Ping"].Text = "📡 Ping: " .. ping .. " ms"
    
    -- Stronghold Timer (Check every 60 frames)

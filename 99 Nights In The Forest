        if obj:IsA("BasePart") and obj.CanCollide then
            foundGround = true
            if obj.Position.Y < lowestY then
                lowestY = obj.Position.Y
            end
        end
    end
    
    if foundGround and lowestY < 0 then
        voidY = lowestY - 50
    else
        voidY = -500
    end
    
    if savedSettings.voidTextBoxRef then
        savedSettings.voidTextBoxRef.Text = tostring(voidY)
    end
    print("🌀 Void re-detected: Y = " .. voidY)
end)


    })
    
    local listLayout = new("UIListLayout", {
        Parent = tabContent,
        Padding = UDim.new(0, 10),
        SortOrder = Enum.SortOrder.LayoutOrder
    })
    
    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabContent.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 20)
    end)
    
    tabs[name] = tabContent
    tabButtons[name] = tabBtn
    
    tabBtn.MouseButton1Click:Connect(function()
        for tabName, content in pairs(tabs) do
            content.Visible = false
            tabButtons[tabName].BackgroundColor3 = Color3.fromRGB(40, 40, 45)
            tabButtons[tabName].TextColor3 = Color3.fromRGB(200, 200, 200)
        end
        tabContent.Visible = true
        tabBtn.BackgroundColor3 = Color3.fromRGB(138, 43, 226)
        tabBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        currentTab = name
    end)
    
    return tabContent
end


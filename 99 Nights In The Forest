-- ── Hook print / warn ────────────────────────────────────────
-- Store originals so they still work normally
local _origPrint = print
local _origWarn  = warn

print = function(...)
    local parts = {}
    for i = 1, select("#", ...) do
        parts[i] = tostring(select(i, ...))
    end
    local msg = table.concat(parts, "\t")
    _origPrint(...)
    pcall(addConsoleEntry, "print", msg)
end

warn = function(...)
    local parts = {}
    for i = 1, select("#", ...) do
        parts[i] = tostring(select(i, ...))
    end
    local msg = table.concat(parts, "\t")
    _origWarn(...)
    pcall(addConsoleEntry, "warn", msg)
end


-- Anti-Lag Speed Toggle (NEW)
createToggle(tab3, "⚡ Anti-Lag Speed Maintenance", function(enabled)
    speedMaintenanceEnabled = enabled
    
    if enabled then
        if speedMaintenanceConnection then speedMaintenanceConnection:Disconnect() end
        
        local hum = getHumanoid()
        if hum then
            targetSpeed = hum.WalkSpeed
            
            speedMaintenanceConnection = RunService.Heartbeat:Connect(function()
                if not speedMaintenanceEnabled then return end
                
                local hum = getHumanoid()
                local hrp = getHrp()
                if not hum or not hrp then return end
                
                -- Force speed to stay at target (ignores lag)
                hum.WalkSpeed = targetSpeed
                
                -- Velocity-based anti-lag
                if hum.MoveDirection.Magnitude > 0 then
                    -- Player is trying to move
                    local currentVelocity = hrp.AssemblyLinearVelocity
                    local horizontalVelocity = Vector3.new(currentVelocity.X, 0, currentVelocity.Z)
                    
                    -- If velocity is too low (lag detected), force it
                    if horizontalVelocity.Magnitude < targetSpeed * 0.5 then
                        local moveDirection = hum.MoveDirection
                        local targetVelocity = moveDirection * targetSpeed
                        
                        -- Force velocity to maintain speed during lag
                        hrp.AssemblyLinearVelocity = Vector3.new(
                            targetVelocity.X,
                            currentVelocity.Y, -- Keep Y for jumping
                            targetVelocity.Z
                        )
                    end
                end
            end)
            
            print("⚡ Anti-Lag Speed: ON - Speed locked at " .. targetSpeed)
        end
    else
        if speedMaintenanceConnection then
            speedMaintenanceConnection:Disconnect()
            speedMaintenanceConnection = nil
        end
        print("❌ Anti-Lag Speed: OFF")
    end
end)


local function scanCrystalShop()
    local folder = ReplicatedStorage:FindFirstChild("cPetShopFolder")
    if not folder then return end
    local pets, auras = {}, {}
    for _, child in ipairs(folder:GetChildren()) do
        local priceFolder = child:FindFirstChild("priceValue")
        if not priceFolder then continue end
        local priceTypeObj = priceFolder:FindFirstChild("priceType")
        local priceType = priceTypeObj and priceTypeObj:IsA("StringValue") and priceTypeObj.Value or ""
        if priceType:lower():gsub("^%s*(.-)%s*$", "%1") == "tokens" then continue end
        local imageId = ""
        local imageObj = child:FindFirstChild("imageValue")
        if imageObj and imageObj:IsA("StringValue") then imageId = imageObj.Value end
        local rarity = ""
        local rarityObj = child:FindFirstChild("rarityValue")
        if rarityObj and rarityObj:IsA("StringValue") then rarity = rarityObj.Value end
        local cost = 0
        if priceFolder:IsA("NumberValue") or priceFolder:IsA("IntValue") then cost = priceFolder.Value end
        local costType = priceTypeObj and priceTypeObj:IsA("StringValue") and priceTypeObj.Value or ""
        local powerUpColor = Color3.new(1, 1, 1)
        local colorObj = child:FindFirstChild("powerUpColor")
        if colorObj and colorObj:IsA("Color3Value") then powerUpColor = colorObj.Value end
        local data = { name = child.Name, imageId = imageId, rarity = rarity, cost = cost, costType = costType, folderChild = child, powerUpColor = powerUpColor }
        if child:FindFirstChild("isPowerUp") then table.insert(auras, data) else table.insert(pets, data) end
    end
    local rarityOrder = {["Basic"] = 1, ["Advanced"] = 2, ["Rare"] = 3, ["Epic"] = 4, ["Unique"] = 5}
    local function sortFunc(a, b) 
        local oA, oB = rarityOrder[a.rarity] or 99, rarityOrder[b.rarity] or 99
        if oA == oB then return a.cost == b.cost and a.name < b.name or a.cost < b.cost end
        return oA < oB 
    end
    table.sort(pets, sortFunc)
    table.sort(auras, sortFunc)
    petList, auraList = pets, auras
end

scanCrystalShop()


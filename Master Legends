                for _, pet in ipairs(rarityFolder:GetChildren()) do
                    local name = pet.Name
                    petCounts[name] = (petCounts[name] or 0) + 1
                end
            end
        end
    end
    if targetPlayer:FindFirstChild("powerUpsFolder") then
        for _, rarityFolder in ipairs(targetPlayer.powerUpsFolder:GetChildren()) do
            if rarityFolder:IsA("Folder") then
                for _, aura in ipairs(rarityFolder:GetChildren()) do
                    local name = aura.Name
                    auraCounts[name] = (auraCounts[name] or 0) + 1
                end
            end
        end
    end
    local petText = "--- PET STORAGE ---\n"
    if next(petCounts) then
        for name, count in pairs(petCounts) do
            petText = petText .. name .. " - " .. count .. "\n"
        end

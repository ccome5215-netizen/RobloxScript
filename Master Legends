local auraRefsBasic, auraRefsAdv, auraRefsRare, auraRefsEpic, auraRefsUnique = {}, {}, {}, {}, {}
local PlayerInventoryCache = {}
local PlayerInventoryChanged = {}

local function getPetAuraState(item)
    local state = {}
    local evObj = item:FindFirstChild("Evolved") or item:FindFirstChild("evolved")
    state.evolved = evObj and evObj:IsA("BoolValue") and evObj.Value or false
    local expObj = item:FindFirstChild("exp")
    state.exp = expObj and expObj.Value or 0
    local lvlObj = item:FindFirstChild("level")
    state.level = lvlObj and lvlObj.Value or 1
    local reqObj = item:FindFirstChild("requiredRebirths")
    state.reqReb = reqObj and reqObj.Value or 0
    local perks = item:FindFirstChild("perksFolder")
    if perks then
        for _, pName in ipairs({"strength", "durability", "agility", "damage"}) do
            local pObj = perks:FindFirstChild(pName)
            if pObj then state[pName] = pObj:IsA("ValueBase") and pObj.Value or (pObj:FindFirstChild("Value") and pObj.Value.Value) or 0 end
        end
    end
    return state
end

local function statesEqual(s1, s2)
    for k, v in pairs(s1) do if s2[k] ~= v then return false end end
    for k, v in pairs(s2) do if s1[k] ~= v then return false end end
    return true
end

local function setupItemTracking(item, playerName)
    local function checkChange()
        if not PlayerInventoryCache[playerName] or not PlayerInventoryCache[playerName][item] then return end
        local newState = getPetAuraState(item)
        local oldState = PlayerInventoryCache[playerName][item]
        if not statesEqual(oldState, newState) then
            PlayerInventoryChanged[playerName] = PlayerInventoryChanged[playerName] or {}
            PlayerInventoryChanged[playerName][item] = true
        end
        PlayerInventoryCache[playerName][item] = newState
    end
    local function connectVal(obj) 
        if obj and obj:IsA("ValueBase") then obj:GetPropertyChangedSignal("Value"):Connect(checkChange) end 
    end
    connectVal(item:FindFirstChild("Evolved") or item:FindFirstChild("evolved"))
    connectVal(item:FindFirstChild("exp"))
    connectVal(item:FindFirstChild("level"))
    connectVal(item:FindFirstChild("requiredRebirths"))
    local perks = item:FindFirstChild("perksFolder")
    if perks then
        for _, pName in ipairs({"strength", "durability", "agility", "damage"}) do
            local pObj = perks:FindFirstChild(pName)
            if pObj then 
                if pObj:IsA("ValueBase") then connectVal(pObj) else connectVal(pObj:FindFirstChild("Value")) end 
            end
        end
    end
end

local function initializePlayerInventory(playerName)
    if PlayerInventoryCache[playerName] then return end
    PlayerInventoryCache[playerName] = {}
    PlayerInventoryChanged[playerName] = {}
    local targetPlayer = Players:FindFirstChild(playerName)
    if not targetPlayer then return end
    local function scanFolder(folder)
        if not folder then return end
        for _, item in ipairs(folder:GetChildren()) do
            PlayerInventoryCache[playerName][item] = getPetAuraState(item)
            setupItemTracking(item, playerName)
        end
    end
    local petsF = targetPlayer:FindFirstChild("petsFolder")
    if petsF then for _, sub in ipairs(petsF:GetChildren()) do scanFolder(sub) end end
    local powerUpsF = targetPlayer:FindFirstChild("powerUpsFolder")
    if powerUpsF then for _, sub in ipairs(powerUpsF:GetChildren()) do scanFolder(sub) end end
end

local function refreshPetDropdown(folder, dropdownObj, refStore, playerName, isAura)
    if not folder or not playerName or not State.trackStats then
        dropdownObj.refresh({"Nothing Here"})
        if refStore then table.clear(refStore) end
        return
    end
    initializePlayerInventory(playerName)
    if isAura then
        State.initialAuras[playerName] = State.initialAuras[playerName] or {}
    else
        State.initialPets[playerName] = State.initialPets[playerName] or {}
    end
    local counts, options, itemRefs = {}, {}, {}
    for _, item in ipairs(folder:GetChildren()) do
        local baseName = item.Name
        counts[baseName] = (counts[baseName] or 0) + 1
        local state = getPetAuraState(item)
        local isNew = "No"
        if isAura then
            if not State.initialAuras[playerName][item] then isNew = "Yes" end
        else
            if not State.initialPets[playerName][item] then isNew = "Yes" end
        end
        local cleanName = baseName .. " Level:" .. state.level .. " XP:" .. state.exp .. " Evolved:" .. tostring(state.evolved)
        table.insert(options, cleanName)
        itemRefs[cleanName] = item
    end
    if #options == 0 then options = {"Nothing Here"} end
    dropdownObj.refresh(options)
    if refStore then table.clear(refStore); for k, v in pairs(itemRefs) do refStore[k] = v end end
end

local function handleItemSelection(label, refTable, detailLabel)
    if not label or label == "Nothing Here" then return end
    local item = refTable[label]
    if item then
        local newState = getPetAuraState(item)
        local txt = "Evolved: " .. tostring(newState.evolved) .. "\nXP: " .. formatNum(newState.exp) .. "\nLevel: " .. formatNum(newState.level) .. "\nRequires Rebirth: " .. formatNum(newState.reqReb) .. "\nPerks:\n"
        for _, pName in ipairs({"strength", "durability", "agility", "damage"}) do
            local fv = newState[pName] or "Not Found"
            txt = txt .. pName:sub(1,1):upper() .. pName:sub(2) .. ": " .. formatNum(fv) .. "\n"
        end
        detailLabel.Text = txt
    else
        detailLabel.Text = "Select a " .. (detailLabel == petDetails and "Pet" or "Aura") .. " to view stats"
    end
end


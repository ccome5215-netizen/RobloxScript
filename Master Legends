            player.Character.HumanoidRootPart.CFrame = State.preGlitchPos 
        end
        if callback then callback() end
    elseif method == "NonTeleport" then
        State.isTransitioning = true
        task.spawn(function()
            task.wait(1)
            for rock, data in pairs(rockCache) do
                if rock and rock.Parent then
                    rock.Size, rock.CanCollide, rock.CFrame, rock.Anchored = data.Size, data.CanCollide, data.CFrame, data.Anchored
                    toggleRockVisuals(rock.Parent, true)
                end
            end
            table.clear(rockCache)
            State.isTransitioning = false
            if callback then callback() end
        end)
    else 
        if callback then callback() end 
    end
end


local function getRockInstance(name)
    local data = rockData[name]
    if not data then return nil end
    local folder = workspace:FindFirstChild("machinesFolder")
    if not folder then return nil end
    for _, v in ipairs(folder:GetChildren()) do
        local success, isMatch = pcall(function()
            local rockPart = v:FindFirstChild("Rock")
            if rockPart then
                local rockGui = rockPart:FindFirstChild("rockGui")
                if rockGui then
                    local rockNameLabel = rockGui:FindFirstChild("rockName")
                    if rockNameLabel and rockNameLabel:IsA("TextLabel") then
                        return rockNameLabel.Text == name or rockNameLabel.Text == data.name
                    end
                end
            end
            return false
        end)
        if success and isMatch then return v end
    end
    return nil
end


local function startAutoGym()
    stopAutoGym()
    if not State.selectedMap or not State.selectedGym then return end
    State.autoGym = true
    local lastTpTime = 0
    State.lastSelectedMap = State.selectedMap
    State.lastSelectedGym = State.selectedGym
    State.autoGymThread = task.spawn(function()
        while State.autoGym and State.selectedMap and State.selectedGym do
            task.wait()
            if State.stopEverything then continue end
            local gym = gymData[State.selectedMap] and gymData[State.selectedMap][State.selectedGym]
            if not gym or (gym.cost and getStrength() < gym.cost) then continue end
            if State.selectedMap == "Muscle King Island" and not isLocalPlayerMuscleKing() and not isMuscleKingNone() then continue end
            local char = player.Character
            if not char then continue end
            local root, hum = char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
            if not root or not hum or hum.Health <= 0 then continue end
            local gymChanged = (State.lastSelectedMap ~= State.selectedMap or State.lastSelectedGym ~= State.selectedGym)
            if gymChanged then
                State.lastSelectedMap = State.selectedMap
                State.lastSelectedGym = State.selectedGym
                if hum.Sit then hum.Sit = false; task.wait(0.2) end
            end
            if hum.Sit then continue end
            if tick() - lastTpTime >= 0.5 then
                pcall(function() root.CFrame = CFrame.new(gym.pos + Vector3.new(0, 4, 0)); root.AssemblyLinearVelocity = Vector3.zero end)
                lastTpTime = tick()
            end
            local seat = findBestSeat(gym.pos)
            if seat then fireMachineInteract(seat) end
        end
        State.autoGym = false
    end)
end


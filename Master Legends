        local durStat = plr:FindFirstChild("Durability")
        if durStat then dur = durStat.Value end
        table.insert(data, { name = plr.DisplayName .. " (@" .. plr.Name .. ")", strength = str, rebirth = reb, durability = dur })
    end
    table.sort(data, function(a, b) return a.strength > b.strength end)
    State.leaderboardData = data

local disabledMotorMap = {}

local function getEffectiveTargetSet()
    local effective = {}
    for _, srcSet in pairs(killSources) do
        for name, _ in pairs(srcSet) do
            local targetPlayer = Players:FindFirstChild(name)
            if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
                effective[name] = true
            end
        end
    end
    return effective
end

local function restoreAllMotor6Ds(targetName)
    if disabledMotorMap[targetName] then
        for _, entry in ipairs(disabledMotorMap[targetName]) do
            pcall(function() entry[1].Parent = entry[2] end)
        end
        disabledMotorMap[targetName] = nil
    end
end

local function disableMotor6DsForTarget(char, targetName)
    if disabledMotorMap[targetName] then return end
    disabledMotorMap[targetName] = {}
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, motor in ipairs(char:GetDescendants()) do
        if motor:IsA("Motor6D") and (motor.Name == "RootJoint" or motor.Name == "Root") then
            if motor.Part0 == hrp or motor.Part1 == hrp then
                table.insert(disabledMotorMap[targetName], {motor, motor.Parent})
                motor.Parent = nil
            end
        end
    end
end

local function setupKillerCharListener(targetPlayer)
    targetPlayer.CharacterAdded:Connect(function(newChar)
        local name = targetPlayer.Name
        task.wait(0.1)
        restoreAllMotor6Ds(name)
        local effective = getEffectiveTargetSet()
        if effective[name] and newChar then
            disableMotor6DsForTarget(newChar, name)
        end
    end)
end


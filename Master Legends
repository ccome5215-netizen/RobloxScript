local function onUnload()
    for name in pairs(disabledMotorMap) do
        restoreAllMotor6Ds(name)
    end
    for _, loop in ipairs(getgenv().ML_Expert_Loops or {}) do
        if type(loop) == "thread" then pcall(task.cancel, loop) elseif type(loop) == "table" and loop.Disconnect then pcall(loop.Disconnect, loop) end
    end
    if getgenv().ML_Expert_UI then pcall(function() getgenv().ML_Expert_UI:Destroy() end) end
    if State.flyBody then
        if State.flyBody.Velocity then State.flyBody.Velocity:Destroy() end
        if State.flyBody.Gyro then State.flyBody.Gyro:Destroy() end
    end
    if slipperyPlatform then slipperyPlatform:Destroy() end
    for rock, data in pairs(rockCache) do
        if rock and rock.Parent then
            rock.Size, rock.CanCollide, rock.CFrame, rock.Anchored = data.Size, data.CanCollide, data.CFrame, data.Anchored
            toggleRockVisuals(rock.Parent, true)
        end
    end
end


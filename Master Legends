                        label.Text = s .. ": " .. formatNum(current) .. (s == "Rebirth Multiplier" and "%" or "") .. gainStr
                    else label.Text = s .. ": " .. tostring(rawVal) end
                end

                local uStr, ultF = "", tp:FindFirstChild("ultimatesFolder")
                if ultF then for _, u in ipairs(ultF:GetChildren()) do uStr = uStr .. u.Name .. ": " .. formatNum(u.Value) .. "\n" end end

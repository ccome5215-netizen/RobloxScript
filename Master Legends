local function updateInventoryDetails()
    local itemCounts = {}
    local targetPlayer = player
    if State.statsTarget then
        local tp = Players:FindFirstChild(State.statsTarget)
        if tp then targetPlayer = tp end
    end
    local bp = targetPlayer:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if item:IsA("Tool") and item.Name ~= "Weight" and item.Name ~= "Pushups" and item.Name ~= "Situps" and item.Name ~= "Handstands" and item.Name ~= "Punch" and item.Name ~= "Ground Slam" and item.Name ~= "Stomp" then
                local name = item.Name
                itemCounts[name] = (itemCounts[name] or 0) + 1
            end
        end
    end
    local text = "--- INVENTORY ---\n"
    if next(itemCounts) then
        for name, count in pairs(itemCounts) do
            text = text .. name .. " - " .. count .. "\n"
        end
    else
        text = text .. "Nothing Here\n"
    end
    inventoryDetailsLabel.Text = text
end

local function updateStorageDetails()
    local petCounts = {}
    local auraCounts = {}
    if not State.trackStats then
        petStorageLabel.Text = "--- PET STORAGE ---\nNothing Here"
        auraStorageLabel.Text = "--- AURA STORAGE ---\nNothing Here"
        inventoryDetailsLabel.Text = "--- INVENTORY ---\nNothing Here"
        return
    end
    local targetPlayer = player
    if State.statsTarget then
        local tp = Players:FindFirstChild(State.statsTarget)
        if tp then targetPlayer = tp end
    end
    if targetPlayer:FindFirstChild("petsFolder") then
        for _, rarityFolder in ipairs(targetPlayer.petsFolder:GetChildren()) do

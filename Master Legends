local function createDropdown(parent, text, options, multi, callback, checkStateFunc, searchable)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1, -10, 0, 30)
    container.BackgroundTransparency = 1
    local headerBtn = Instance.new("TextButton", container)
    headerBtn.Size = UDim2.new(1, 0, 0, 30)
    headerBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    headerBtn.Text = text .. " v"
    headerBtn.TextColor3 = Color3.new(1, 1, 1)
    headerBtn.ZIndex = 12
    headerBtn.AutoButtonColor = false
    headerBtn.Font = Enum.Font.Gotham
    headerBtn.TextSize = 14
    local list = Instance.new("ScrollingFrame", container)
    list.Position = UDim2.fromOffset(0, 30)
    list.Visible = false
    list.ZIndex = 10
    list.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    list.ScrollBarThickness = isMobile and 6 or 4
    list.ClipsDescendants = true
    local searchBox = nil
    if searchable then
        searchBox = Instance.new("TextBox", container)
        searchBox.Size = UDim2.new(1, 0, 0, 25)
        searchBox.Position = UDim2.fromOffset(0, 30)
        searchBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        searchBox.Text = ""
        searchBox.PlaceholderText = "Search..."
        searchBox.TextColor3 = Color3.new(1, 1, 1)
        searchBox.Visible = false
        searchBox.ZIndex = 11
        list.Position = UDim2.fromOffset(0, 55)
    end
    local currentOptions = options
    local function refresh(newOpts)
        if newOpts then options = newOpts end
        currentOptions = options
        for _, v in ipairs(list:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        local searchText = searchBox and searchBox.Text:lower() or ""
        local visibleCount = 0
        for i, opt in ipairs(currentOptions) do
            local optStr = tostring(opt)
            if searchText == "" or optStr:lower():find(searchText, 1, true) then
                visibleCount = visibleCount + 1
                local o = Instance.new("TextButton", list)
                o.Size = UDim2.new(1, 0, 0, 25)
                o.Position = UDim2.fromOffset(0, (visibleCount - 1) * 25)
                o.Text = optStr
                o.TextColor3 = Color3.new(1, 1, 1)
                o.ZIndex = 11
                if multi and checkStateFunc then
                    o.BackgroundColor3 = checkStateFunc(opt) and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
                else 
                    o.BackgroundColor3 = Color3.fromRGB(60, 60, 60) 
                end
                o.MouseButton1Click:Connect(function()
                    if not multi then
                        headerBtn.Text = optStr .. " v"
                        list.Visible = false
                        if searchBox then searchBox.Visible = false end
                        container.Size = UDim2.new(1, -10, 0, 30)
                        callback(opt)
                    else
                        local newState = callback(opt)
                        o.BackgroundColor3 = newState and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 60)
                    end
                end)
            end
        end
        local listHeight = math.min(visibleCount * 25, 150)
        if list.Visible then
            local totalHeight = 30 + (searchBox and searchBox.Visible and 25 or 0) + listHeight
            container.Size = UDim2.new(1, -10, 0, totalHeight)
            list.Size = UDim2.new(1, 0, 0, listHeight)
        end
        list.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 25)
    end
    if searchBox then
        searchBox:GetPropertyChangedSignal("Text"):Connect(function() if list.Visible then refresh() end end)
    end
    headerBtn.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        if searchBox then searchBox.Visible = list.Visible end
        local listHeight = math.min(#currentOptions * 25, 150)
        local totalHeight = 30 + (searchBox and 25 or 0) + listHeight
        container.Size = list.Visible and UDim2.new(1, -10, 0, totalHeight) or UDim2.new(1, -10, 0, 30)
        list.Size = UDim2.new(1, 0, 0, listHeight)
        list.CanvasSize = UDim2.new(0, 0, 0, #currentOptions * 25)
        if list.Visible then refresh() end
    end)
    refresh()
    return { refresh = refresh, setHeaderText = function(txt) headerBtn.Text = txt end, setValue = function(val) if not multi then headerBtn.Text = tostring(val) .. " v"; callback(val) end end }
end


local function getTeleportPosForMap(currentMap)
    if not currentMap or currentMap == "" then return Vector3.new(4.4, 7.3, 132.8) end
    local lowerMap = currentMap:lower()
    if lowerMap:find("jungle") then return Vector3.new(-8685.6, 6.7, 2392.3)
    elseif lowerMap:find("muscle king") then return Vector3.new(-8625.9, 17.1, -5730.4)
    elseif lowerMap:find("beach") then return Vector3.new(4.4, 7.3, 132.8)
    elseif lowerMap:find("tiny") then return Vector3.new(-33.6, 7.4, 1892.8)
    elseif lowerMap:find("frozen") then return Vector3.new(-2623.0, 7.3, -409.0)
    elseif lowerMap:find("mystic") then return Vector3.new(2250.7, 7.3, 1073.2)
    elseif lowerMap:find("inferno") then return Vector3.new(-6758.9, 7.3, -1284.9)
    elseif lowerMap:find("legend") then return Vector3.new(4603.2, 991.4, -3897.8)
    else return Vector3.new(4.4, 7.3, 132.8) end
end


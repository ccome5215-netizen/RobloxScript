                    end
                end
                petEquipLabel.Text = petEquipStr == "" and "None" or petEquipStr
            else resetStatsUI() end
         else 
            for s, label in pairs(statsDisp) do label.Text = s .. ": None" end 
            if ultList then ultList.Text = "None" end
            if gpList then gpList.Text = "None" end
            if petEquipLabel then petEquipLabel.Text = "None" end
        end
    end

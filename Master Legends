local function checkForUpdate()
    local success, remoteScript = pcall(function()
        return game:HttpGet("https://raw.githubusercontent.com/ccome5215-netizen/RobloxScript/refs/heads/main/Master%20Legends")
    end)
    if success and remoteScript then
        local remoteVersion = remoteScript:match('local%s+SCRIPT_VERSION%s*=%s*"([^"]+)"')
        if remoteVersion and remoteVersion ~= SCRIPT_VERSION then
            local updateGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
            updateGui.Name = "ML_UpdateGui"
            updateGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
            updateGui.ResetOnSpawn = false

            local frame = Instance.new("Frame", updateGui)
            frame.Size = UDim2.fromOffset(320, 160)
            frame.Position = UDim2.new(0.5, -160, 0.5, -80)
            frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            frame.BorderSizePixel = 0
            Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

            local title = Instance.new("TextLabel", frame)
            title.Size = UDim2.new(1, 0, 0, 40)
            title.Position = UDim2.fromOffset(0, 10)
            title.BackgroundTransparency = 1
            title.Text = "New Update Required"
            title.TextColor3 = Color3.fromRGB(255, 50, 50)
            title.Font = Enum.Font.GothamBold
            title.TextSize = 20

            local loadingLabel = Instance.new("TextLabel", frame)
            loadingLabel.Size = UDim2.new(1, 0, 0, 30)
            loadingLabel.Position = UDim2.fromOffset(0, 55)
            loadingLabel.BackgroundTransparency = 1
            loadingLabel.Text = "Loading..."
            loadingLabel.TextColor3 = Color3.new(1, 1, 1)
            loadingLabel.Font = Enum.Font.GothamBold
            loadingLabel.TextSize = 16

            local timeLabel = Instance.new("TextLabel", frame)
            timeLabel.Size = UDim2.new(1, 0, 0, 25)
            timeLabel.Position = UDim2.fromOffset(0, 90)
            timeLabel.BackgroundTransparency = 1
            timeLabel.Text = "Remaining Time: (3 Seconds)"
            timeLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
            timeLabel.Font = Enum.Font.Gotham
            timeLabel.TextSize = 14

            task.spawn(function()
                local dots = 0
                while updateGui.Parent do
                    dots = (dots + 1) % 4
                    loadingLabel.Text = "Loading" .. string.rep(".", dots)
                    task.wait(0.4)
                end
            end)

            for i = 3, 1, -1 do
                timeLabel.Text = "Remaining Time: (" .. i .. " Seconds)"
                task.wait(1)
            end

            updateGui:Destroy()
            loadstring(remoteScript)()
            return true
        end
    end
    return false
end

